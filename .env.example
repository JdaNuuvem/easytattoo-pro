# === PostgreSQL ===
POSTGRES_USER=easytattoo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=easytattoo

# === API ===
DATABASE_URL=postgresql://easytattoo:CHANGE_ME_STRONG_PASSWORD@postgres:5432/easytattoo?schema=public
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_64_CHARS
JWT_EXPIRATION=7d
UPLOAD_DIR=./uploads
PORT=3000

# === Redis ===
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# === CORS (comma-separated origins) ===
CORS_ORIGINS=https://app.seudominio.com,https://seudominio.com

# === Web (Next.js) ===
NEXT_PUBLIC_API_URL=https://api.seudominio.com
