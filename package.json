{
  "name": "easytattoo-pro",
  "version": "1.0.0",
  "private": true,
  "description": "EasyTattoo Pro - Sistema profissional de gerenciamento de estudio de tatuagem",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:api": "pnpm --filter api run dev",
    "dev:web": "pnpm --filter web run dev",
    "build": "pnpm -r run build",
    "build:api": "pnpm --filter api run build",
    "build:web": "pnpm --filter web run build",
    "start": "pnpm --parallel -r run start",
    "db:migrate": "pnpm --filter api run db:migrate",
    "db:generate": "pnpm --filter api run db:generate",
    "db:seed": "pnpm --filter api run db:seed",
    "db:studio": "pnpm --filter api run db:studio",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
